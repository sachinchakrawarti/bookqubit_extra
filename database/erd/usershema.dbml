// ============================================
// BOOKQUBIT USER MANAGEMENT ERD
// Complete User-related Database Schema with Sample Data
// ============================================

// Project: BookQubit - User Module
// Version: 1.0.0
// Database: SQLite
// Date: 2024

// ============================================
// ENUMS
// ============================================

Enum user_role {
    user
    editor
    admin
    super_admin
}

Enum user_status {
    active
    inactive
    suspended
    banned
    pending_verification
}

Enum gender {
    male
    female
    other
    prefer_not_to_say
}

Enum notification_type {
    email
    push
    in_app
    sms
}

Enum notification_priority {
    low
    medium
    high
    urgent
}

Enum device_type {
    web
    mobile
    tablet
    desktop
    api
}

Enum login_status {
    success
    failed
    locked
    expired
}

// ============================================
// TABLES
// ============================================

// --------------------------------------------
// Table: users (MAIN USER TABLE)
// --------------------------------------------
Table users {
    id integer [primary key]
    username varchar(100) [unique, not null]
    email varchar(200) [unique, not null]
    phone varchar(20)
    password_hash varchar(255) [not null]
    password_salt varchar(50)
    full_name varchar(200)
    avatar_url text
    bio text
    date_of_birth datetime
    gender gender
    country varchar(100)
    city varchar(100)
    timezone varchar(50)
    language_preference varchar(20)
    role user_role [default: 'user']
    status user_status [default: 'active']
    is_verified boolean [default: false]
    is_2fa_enabled boolean [default: false]
    email_verified_at datetime
    phone_verified_at datetime
    last_login datetime
    login_count integer [default: 0]
    failed_login_attempts integer [default: 0]
    locked_until datetime
    referral_code varchar(50) [unique]
    referred_by integer
    created_at datetime [default: `CURRENT_TIMESTAMP`]
    updated_at datetime [default: `CURRENT_TIMESTAMP`]
    deleted_at datetime
    
    indexes {
        username [unique]
        email [unique]
        phone
        role
        status
        is_verified
        created_at
        referral_code [unique]
        referred_by
    }
}

// --------------------------------------------
// Table: user_profiles
// --------------------------------------------
Table user_profiles {
    id integer [primary key]
    user_id integer [not null]
    display_name varchar(200)
    first_name varchar(100)
    last_name varchar(100)
    bio text
    website varchar(255)
    company varchar(200)
    job_title varchar(200)
    industry varchar(100)
    education text
    skills text [note: 'JSON array']
    interests text [note: 'JSON array']
    social_links text [note: 'JSON: {twitter, instagram, facebook, linkedin, youtube}']
    profile_visibility varchar(20) [default: 'public']
    show_email boolean [default: false]
    show_phone boolean [default: false]
    show_birthday boolean [default: false]
    created_at datetime [default: `CURRENT_TIMESTAMP`]
    updated_at datetime [default: `CURRENT_TIMESTAMP`]
    
    indexes {
        user_id [unique]
        display_name
        company
        job_title
    }
}

// --------------------------------------------
// Table: user_addresses
// --------------------------------------------
Table user_addresses {
    id integer [primary key]
    user_id integer [not null]
    address_type varchar(20) [default: 'shipping']
    address_line1 varchar(255) [not null]
    address_line2 varchar(255)
    city varchar(100)
    state varchar(100)
    postal_code varchar(20)
    country varchar(100)
    is_default boolean [default: false]
    is_active boolean [default: true]
    created_at datetime [default: `CURRENT_TIMESTAMP`]
    updated_at datetime [default: `CURRENT_TIMESTAMP`]
    
    indexes {
        user_id
        address_type
        is_default
        is_active
    }
}

// --------------------------------------------
// Table: user_sessions
// --------------------------------------------
Table user_sessions {
    id integer [primary key]
    user_id integer [not null]
    token varchar(255) [unique, not null]
    refresh_token varchar(255) [unique]
    ip_address varchar(50)
    user_agent text
    device_type device_type [default: 'web']
    device_name varchar(100)
    platform varchar(50)
    browser varchar(50)
    browser_version varchar(20)
    location varchar(200)
    is_active boolean [default: true]
    expires_at datetime [not null]
    created_at datetime [default: `CURRENT_TIMESTAMP`]
    updated_at datetime [default: `CURRENT_TIMESTAMP`]
    
    indexes {
        token [unique]
        refresh_token [unique]
        user_id
        expires_at
        is_active
    }
}

// --------------------------------------------
// Table: user_login_history
// --------------------------------------------
Table user_login_history {
    id integer [primary key]
    user_id integer [not null]
    status login_status [not null]
    ip_address varchar(50)
    user_agent text
    device_type device_type
    location varchar(200)
    login_method varchar(50)
    failed_reason varchar(200)
    created_at datetime [default: `CURRENT_TIMESTAMP`]
    
    indexes {
        user_id
        created_at
        status
        ip_address
    }
}

// --------------------------------------------
// Table: user_reset_tokens
// --------------------------------------------
Table user_reset_tokens {
    id integer [primary key]
    user_id integer [not null]
    token varchar(255) [unique, not null]
    type varchar(50) [default: 'password']
    expires_at datetime [not null]
    is_used boolean [default: false]
    created_at datetime [default: `CURRENT_TIMESTAMP`]
    
    indexes {
        token [unique]
        user_id
        expires_at
        is_used
    }
}

// --------------------------------------------
// Table: user_verification_tokens
// --------------------------------------------
Table user_verification_tokens {
    id integer [primary key]
    user_id integer [not null]
    token varchar(255) [unique, not null]
    type varchar(50) [default: 'email']
    expires_at datetime [not null]
    is_used boolean [default: false]
    created_at datetime [default: `CURRENT_TIMESTAMP`]
    
    indexes {
        token [unique]
        user_id
        expires_at
        is_used
        type
    }
}

// --------------------------------------------
// Table: user_preferences
// --------------------------------------------
Table user_preferences {
    id integer [primary key]
    user_id integer [not null]
    preference_key varchar(100) [not null]
    preference_value text
    category varchar(50) [default: 'general']
    is_active boolean [default: true]
    created_at datetime [default: `CURRENT_TIMESTAMP`]
    updated_at datetime [default: `CURRENT_TIMESTAMP`]
    
    indexes {
        user_id
        preference_key
        category
        is_active
    }
    
    unique_constraint [user_id, preference_key]
}

// --------------------------------------------
// Table: user_notifications
// --------------------------------------------
Table user_notifications {
    id integer [primary key]
    user_id integer [not null]
    notification_type notification_type [not null]
    priority notification_priority [default: 'medium']
    title varchar(200) [not null]
    message text
    body text
    icon_url text
    link text
    image_url text
    action_label varchar(50)
    action_url text
    is_read boolean [default: false]
    is_dismissed boolean [default: false]
    is_clicked boolean [default: false]
    read_at datetime
    dismissed_at datetime
    clicked_at datetime
    created_at datetime [default: `CURRENT_TIMESTAMP`]
    
    indexes {
        user_id
        notification_type
        is_read
        is_dismissed
        created_at
        priority
    }
}

// --------------------------------------------
// Table: user_notification_settings
// --------------------------------------------
Table user_notification_settings {
    id integer [primary key]
    user_id integer [not null]
    category varchar(50) [not null]
    channel notification_type [not null]
    is_enabled boolean [default: true]
    created_at datetime [default: `CURRENT_TIMESTAMP`]
    updated_at datetime [default: `CURRENT_TIMESTAMP`]
    
    indexes {
        user_id
        category
        channel
        is_enabled
    }
    
    unique_constraint [user_id, category, channel]
}

// --------------------------------------------
// Table: user_devices
// --------------------------------------------
Table user_devices {
    id integer [primary key]
    user_id integer [not null]
    device_token varchar(255) [unique, not null]
    device_type device_type [not null]
    device_name varchar(100)
    platform varchar(50)
    platform_version varchar(20)
    app_version varchar(20)
    model varchar(100)
    manufacturer varchar(100)
    is_active boolean [default: true]
    last_active_at datetime
    created_at datetime [default: `CURRENT_TIMESTAMP`]
    updated_at datetime [default: `CURRENT_TIMESTAMP`]
    
    indexes {
        device_token [unique]
        user_id
        device_type
        is_active
        last_active_at
    }
}

// --------------------------------------------
// Table: user_activities
// --------------------------------------------
Table user_activities {
    id integer [primary key]
    user_id integer [not null]
    activity_type varchar(50) [not null]
    activity_category varchar(50)
    content_type varchar(50)
    content_id integer
    metadata text [note: 'JSON']
    ip_address varchar(50)
    user_agent text
    device_type device_type
    session_id integer
    duration_seconds integer
    is_active boolean [default: true]
    created_at datetime [default: `CURRENT_TIMESTAMP`]
    
    indexes {
        user_id
        activity_type
        activity_category
        content_type
        content_id
        created_at
        is_active
    }
}

// --------------------------------------------
// Table: user_follows
// --------------------------------------------
Table user_follows {
    id integer [primary key]
    follower_user_id integer [not null]
    following_user_id integer [not null]
    status varchar(20) [default: 'active']
    created_at datetime [default: `CURRENT_TIMESTAMP`]
    updated_at datetime [default: `CURRENT_TIMESTAMP`]
    
    indexes {
        follower_user_id
        following_user_id
        status
    }
    
    unique_constraint [follower_user_id, following_user_id]
}

// --------------------------------------------
// Table: user_favorites
// --------------------------------------------
Table user_favorites {
    id integer [primary key]
    user_id integer [not null]
    content_type varchar(50) [not null]
    content_id integer [not null]
    created_at datetime [default: `CURRENT_TIMESTAMP`]
    
    indexes {
        user_id
        content_type
        content_id
        created_at
    }
    
    unique_constraint [user_id, content_type, content_id]
}

// --------------------------------------------
// Table: user_ratings
// --------------------------------------------
Table user_ratings {
    id integer [primary key]
    user_id integer [not null]
    content_type varchar(50) [not null]
    content_id integer [not null]
    rating integer [check: `rating >= 1 AND rating <= 5`]
    is_anonymous boolean [default: false]
    created_at datetime [default: `CURRENT_TIMESTAMP`]
    updated_at datetime [default: `CURRENT_TIMESTAMP`]
    
    indexes {
        user_id
        content_type
        content_id
        rating
        created_at
    }
    
    unique_constraint [user_id, content_type, content_id]
}

// --------------------------------------------
// Table: user_stats
// --------------------------------------------
Table user_stats {
    id integer [primary key]
    user_id integer [not null]
    total_books_read integer [default: 0]
    total_comics_read integer [default: 0]
    total_reviews_written integer [default: 0]
    total_favorites integer [default: 0]
    total_downloads integer [default: 0]
    total_shares integer [default: 0]
    total_followers integer [default: 0]
    total_following integer [default: 0]
    reading_streak integer [default: 0]
    longest_reading_streak integer [default: 0]
    last_activity_date datetime
    total_reading_time integer [default: 0]
    total_pages_read integer [default: 0]
    average_rating_given decimal(3,2) [default: 0.00]
    achievements_count integer [default: 0]
    created_at datetime [default: `CURRENT_TIMESTAMP`]
    updated_at datetime [default: `CURRENT_TIMESTAMP`]
    
    indexes {
        user_id [unique]
        reading_streak
        last_activity_date
        total_books_read
        total_reviews_written
    }
}

// --------------------------------------------
// Table: user_badges
// --------------------------------------------
Table user_badges {
    id integer [primary key]
    user_id integer [not null]
    badge_name varchar(100) [not null]
    badge_type varchar(50)
    badge_level integer [default: 1]
    badge_icon text
    badge_description text
    points_earned integer [default: 0]
    progress integer [default: 0]
    unlocked_at datetime
    created_at datetime [default: `CURRENT_TIMESTAMP`]
    updated_at datetime [default: `CURRENT_TIMESTAMP`]
    
    indexes {
        user_id
        badge_type
        badge_name
        unlocked_at
    }
    
    unique_constraint [user_id, badge_name]
}

// --------------------------------------------
// Table: user_subscriptions
// --------------------------------------------
Table user_subscriptions {
    id integer [primary key]
    user_id integer [not null]
    subscription_type varchar(50) [not null]
    plan_name varchar(100)
    plan_price decimal(10,2)
    currency varchar(10) [default: 'USD']
    billing_cycle varchar(20)
    start_date datetime [not null]
    end_date datetime
    is_active boolean [default: true]
    auto_renew boolean [default: false]
    stripe_customer_id varchar(100)
    stripe_subscription_id varchar(100)
    payment_method varchar(50)
    last_payment_date datetime
    next_payment_date datetime
    created_at datetime [default: `CURRENT_TIMESTAMP`]
    updated_at datetime [default: `CURRENT_TIMESTAMP`]
    
    indexes {
        user_id
        subscription_type
        is_active
        end_date
        stripe_customer_id
        stripe_subscription_id
    }
}

// --------------------------------------------
// Table: user_invitations
// --------------------------------------------
Table user_invitations {
    id integer [primary key]
    inviter_user_id integer [not null]
    invitee_email varchar(200) [not null]
    invitee_name varchar(200)
    token varchar(255) [unique, not null]
    role user_role [default: 'user']
    message text
    expires_at datetime [not null]
    is_accepted boolean [default: false]
    accepted_at datetime
    created_at datetime [default: `CURRENT_TIMESTAMP`]
    updated_at datetime [default: `CURRENT_TIMESTAMP`]
    
    indexes {
        token [unique]
        inviter_user_id
        invitee_email
        expires_at
        is_accepted
    }
}

// ============================================
// RELATIONSHIPS (REFERENCES)
// ============================================

// User self-reference (referral)
Ref: users.referred_by > users.id

// User profiles
Ref: user_profiles.user_id > users.id

// User addresses
Ref: user_addresses.user_id > users.id

// User sessions
Ref: user_sessions.user_id > users.id

// User login history
Ref: user_login_history.user_id > users.id

// User reset tokens
Ref: user_reset_tokens.user_id > users.id

// User verification tokens
Ref: user_verification_tokens.user_id > users.id

// User preferences
Ref: user_preferences.user_id > users.id

// User notifications
Ref: user_notifications.user_id > users.id

// User notification settings
Ref: user_notification_settings.user_id > users.id

// User devices
Ref: user_devices.user_id > users.id

// User activities
Ref: user_activities.user_id > users.id
Ref: user_activities.session_id > user_sessions.id

// User follows (self-referencing many-to-many)
Ref: user_follows.follower_user_id > users.id
Ref: user_follows.following_user_id > users.id

// User favorites
Ref: user_favorites.user_id > users.id

// User ratings
Ref: user_ratings.user_id > users.id

// User stats
Ref: user_stats.user_id > users.id

// User badges
Ref: user_badges.user_id > users.id

// User subscriptions
Ref: user_subscriptions.user_id > users.id

// User invitations
Ref: user_invitations.inviter_user_id > users.id

