// ============================================
// BOOKQUBIT DATABASE ERD
// Complete Database Schema in DBML Format
// ============================================

// Project: BookQubit
// Version: 1.0.0
// Database: SQLite
// Date: 2024

// ============================================
// ENUMS
// ============================================

Enum book_status {
    draft
    published
    archived
    deleted
}

Enum review_status {
    pending
    approved
    rejected
}

Enum reading_status {
    to_read
    reading
    completed
    abandoned
    on_hold
}

Enum activity_type {
    view
    download
    favorite
    share
    review
    read
    add_to_list
    purchase
}

Enum content_type {
    book
    comic
    author
    category
    publication
}

Enum trend_type {
    popular
    trending
    rising
    declining
}

Enum trend_period {
    daily
    weekly
    monthly
    yearly
}

Enum user_role {
    user
    editor
    admin
    super_admin
}

// ============================================
// TABLE: languages
// ============================================
Table languages {
    id integer [pk, increment]
    code varchar(20) [unique, not null]
    name varchar(100) [not null]
    native_name varchar(100)
    flag_emoji varchar(10)
    is_active boolean [default: true]
    created_at timestamp [default: `CURRENT_TIMESTAMP`]
    updated_at timestamp [default: `CURRENT_TIMESTAMP`]
    
    indexes {
        code [unique]
        is_active
    }
}

// ============================================
// TABLE: authors
// ============================================
Table authors {
    id integer [pk, increment]
    name varchar(200) [not null]
    bio text
    birth_date date
    death_date date
    nationality varchar(100)
    language_code varchar(20) [ref: > languages.code]
    image_url text
    website varchar(255)
    wikipedia_url varchar(255)
    social_links text [note: 'JSON: {twitter, instagram, facebook, linkedin, youtube}']
    total_books integer [default: 0]
    total_sales integer [default: 0]
    rating decimal(3,2) [default: 0.00]
    is_active boolean [default: true]
    created_at timestamp [default: `CURRENT_TIMESTAMP`]
    updated_at timestamp [default: `CURRENT_TIMESTAMP`]
    
    indexes {
        name
        language_code
        is_active
        rating
    }
}

// ============================================
// TABLE: categories
// ============================================
Table categories {
    id integer [pk, increment]
    name varchar(100) [not null]
    slug varchar(100) [unique, not null]
    description text
    icon varchar(50)
    color varchar(20)
    parent_id integer [ref: > categories.id]
    language_code varchar(20) [ref: > languages.code]
    is_active boolean [default: true]
    created_at timestamp [default: `CURRENT_TIMESTAMP`]
    updated_at timestamp [default: `CURRENT_TIMESTAMP`]
    
    indexes {
        slug [unique]
        parent_id
        language_code
        is_active
    }
}

// ============================================
// TABLE: publications
// ============================================
Table publications {
    id integer [pk, increment]
    name varchar(200) [not null]
    slug varchar(200) [unique, not null]
    description text
    logo_url text
    website varchar(255)
    founded_year integer
    country varchar(100)
    language_code varchar(20) [ref: > languages.code]
    email varchar(100)
    phone varchar(50)
    address text
    is_active boolean [default: true]
    created_at timestamp [default: `CURRENT_TIMESTAMP`]
    updated_at timestamp [default: `CURRENT_TIMESTAMP`]
    
    indexes {
        slug [unique]
        language_code
        is_active
        country
    }
}

// ============================================
// TABLE: books
// ============================================
Table books {
    id integer [pk, increment]
    title varchar(500) [not null]
    slug varchar(500) [unique, not null]
    subtitle varchar(500)
    author_id integer [ref: > authors.id]
    category_id integer [ref: > categories.id]
    language_code varchar(20) [not null, ref: > languages.code]
    publication_id integer [ref: > publications.id]
    description text
    summary text
    excerpt text
    price decimal(10,2) [default: 0.00]
    currency varchar(10) [default: 'USD']
    image_url text
    cover_image text
    page_count integer
    isbn varchar(20) [unique]
    isbn13 varchar(20)
    oclc varchar(50)
    lccn varchar(50)
    publisher varchar(200)
    published_date date
    edition varchar(50)
    format varchar(50)
    rating decimal(3,2) [default: 0.00]
    total_reviews integer [default: 0]
    views integer [default: 0]
    downloads integer [default: 0]
    favorites integer [default: 0]
    shares integer [default: 0]
    status book_status [default: 'published']
    is_featured boolean [default: false]
    is_bestseller boolean [default: false]
    is_new_release boolean [default: false]
    table_of_contents text [note: 'JSON']
    tags text [note: 'JSON array']
    genres text [note: 'JSON array']
    subjects text [note: 'JSON array']
    key_points text [note: 'JSON array']
    geography text [note: 'JSON object']
    buttons text [note: 'JSON object']
    original_language_code varchar(20)
    created_at timestamp [default: `CURRENT_TIMESTAMP`]
    updated_at timestamp [default: `CURRENT_TIMESTAMP`]
    deleted_at timestamp
    
    indexes {
        slug [unique]
        author_id
        category_id
        language_code
        publication_id
        status
        rating
        created_at
        published_date
        is_featured
        is_bestseller
        isbn [unique]
        deleted_at
    }
}

// ============================================
// TABLE: comics
// ============================================
Table comics {
    id integer [pk, increment]
    title varchar(500) [not null]
    slug varchar(500) [unique, not null]
    subtitle varchar(500)
    author_id integer [ref: > authors.id]
    illustrator_id integer [ref: > authors.id]
    category_id integer [ref: > categories.id]
    language_code varchar(20) [not null, ref: > languages.code]
    publication_id integer [ref: > publications.id]
    description text
    summary text
    price decimal(10,2) [default: 0.00]
    currency varchar(10) [default: 'USD']
    cover_image text
    page_count integer
    isbn varchar(20) [unique]
    publisher varchar(200)
    published_date date
    edition varchar(50)
    format varchar(50)
    rating decimal(3,2) [default: 0.00]
    total_reviews integer [default: 0]
    views integer [default: 0]
    downloads integer [default: 0]
    favorites integer [default: 0]
    shares integer [default: 0]
    status book_status [default: 'published']
    is_featured boolean [default: false]
    is_bestseller boolean [default: false]
    is_new_release boolean [default: false]
    series varchar(200)
    issue_number integer
    volume integer
    characters text [note: 'JSON array']
    story_arc text
    art_style varchar(100)
    genres text [note: 'JSON array']
    tags text [note: 'JSON array']
    created_at timestamp [default: `CURRENT_TIMESTAMP`]
    updated_at timestamp [default: `CURRENT_TIMESTAMP`]
    deleted_at timestamp
    
    indexes {
        slug [unique]
        author_id
        illustrator_id
        category_id
        language_code
        publication_id
        status
        rating
        series
        issue_number
    }
}

// ============================================
// TABLE: comic_panels
// ============================================
Table comic_panels {
    id integer [pk, increment]
    comic_id integer [not null, ref: > comics.id]
    page_number integer
    panel_number integer
    image_url text
    dialog text
    narrator text
    sound_effects text
    created_at timestamp [default: `CURRENT_TIMESTAMP`]
    
    indexes {
        comic_id
        page_number
        panel_number
    }
}

// ============================================
// TABLE: comic_characters
// ============================================
Table comic_characters {
    id integer [pk, increment]
    comic_id integer [not null, ref: > comics.id]
    character_name varchar(200) [not null]
    description text
    image_url text
    created_at timestamp [default: `CURRENT_TIMESTAMP`]
    
    indexes {
        comic_id
        character_name
    }
}

// ============================================
// TABLE: reviews
// ============================================
Table reviews {
    id integer [pk, increment]
    content_type content_type [not null]
    content_id integer [not null]
    user_id integer
    user_name varchar(200)
    user_email varchar(200)
    rating integer [check: `rating >= 1 AND rating <= 5`]
    comment text
    title varchar(200)
    is_verified boolean [default: false]
    is_approved boolean [default: false]
    helpful_count integer [default: 0]
    unhelpful_count integer [default: 0]
    created_at timestamp [default: `CURRENT_TIMESTAMP`]
    updated_at timestamp [default: `CURRENT_TIMESTAMP`]
    
    indexes {
        content_type
        content_id
        rating
        created_at
        is_approved
    }
}

// ============================================
// TABLE: review_replies
// ============================================
Table review_replies {
    id integer [pk, increment]
    review_id integer [not null, ref: > reviews.id]
    user_id integer
    user_name varchar(200)
    comment text
    is_approved boolean [default: false]
    created_at timestamp [default: `CURRENT_TIMESTAMP`]
    
    indexes {
        review_id
    }
}

// ============================================
// TABLE: reading_list
// ============================================
Table reading_list {
    id integer [pk, increment]
    user_id integer [not null]
    content_type content_type [not null]
    content_id integer [not null]
    status reading_status [default: 'to_read']
    started_at timestamp
    completed_at timestamp
    progress integer [default: 0]
    rating integer [check: `rating >= 1 AND rating <= 5`]
    notes text
    created_at timestamp [default: `CURRENT_TIMESTAMP`]
    updated_at timestamp [default: `CURRENT_TIMESTAMP`]
    
    indexes {
        user_id
        content_type
        content_id
        status
    }
    
    unique_constraint [user_id, content_type, content_id]
}

// ============================================
// TABLE: book_stats
// ============================================
Table book_stats {
    id integer [pk, increment]
    content_type content_type [not null]
    content_id integer [not null]
    daily_views integer [default: 0]
    weekly_views integer [default: 0]
    monthly_views integer [default: 0]
    daily_downloads integer [default: 0]
    weekly_downloads integer [default: 0]
    monthly_downloads integer [default: 0]
    daily_favorites integer [default: 0]
    weekly_favorites integer [default: 0]
    monthly_favorites integer [default: 0]
    daily_shares integer [default: 0]
    weekly_shares integer [default: 0]
    monthly_shares integer [default: 0]
    date date [not null]
    created_at timestamp [default: `CURRENT_TIMESTAMP`]
    
    indexes {
        content_type
        content_id
        date
    }
    
    unique_constraint [content_type, content_id, date]
}

// ============================================
// TABLE: book_history
// ============================================
Table book_history {
    id integer [pk, increment]
    content_type content_type [not null]
    content_id integer [not null]
    action varchar(50) [not null]
    changes text [note: 'JSON']
    user_id integer
    user_name varchar(200)
    ip_address varchar(50)
    user_agent text
    created_at timestamp [default: `CURRENT_TIMESTAMP`]
    
    indexes {
        content_type
        content_id
        created_at
        action
    }
}

// ============================================
// TABLE: trends
// ============================================
Table trends {
    id integer [pk, increment]
    content_type content_type [not null]
    content_id integer [not null]
    trend_type trend_type [not null]
    score decimal(10,2) [default: 0.00]
    rank integer [default: 0]
    period trend_period [not null]
    start_date date [not null]
    end_date date [not null]
    data text [note: 'JSON']
    created_at timestamp [default: `CURRENT_TIMESTAMP`]
    
    indexes {
        content_type
        content_id
        trend_type
        period
        start_date
        end_date
        rank
    }
    
    unique_constraint [content_type, content_id, trend_type, period, start_date, end_date]
}

// ============================================
// TABLE: trending_topics
// ============================================
Table trending_topics {
    id integer [pk, increment]
    topic_name varchar(200) [not null]
    category varchar(100)
    score decimal(10,2) [default: 0.00]
    rank integer [default: 0]
    period trend_period [not null]
    start_date date [not null]
    end_date date [not null]
    created_at timestamp [default: `CURRENT_TIMESTAMP`]
    
    indexes {
        topic_name
        period
        start_date
        end_date
        rank
    }
    
    unique_constraint [topic_name, period, start_date, end_date]
}

// ============================================
// TABLE: user_activities
// ============================================
Table user_activities {
    id integer [pk, increment]
    user_id integer [not null]
    activity_type activity_type [not null]
    content_type content_type [not null]
    content_id integer [not null]
    metadata text [note: 'JSON']
    ip_address varchar(50)
    user_agent text
    created_at timestamp [default: `CURRENT_TIMESTAMP`]
    
    indexes {
        user_id
        content_type
        content_id
        created_at
        activity_type
    }
}

// ============================================
// TABLE: user_stats
// ============================================
Table user_stats {
    id integer [pk, increment]
    user_id integer [not null]
    total_books_read integer [default: 0]
    total_comics_read integer [default: 0]
    total_reviews_written integer [default: 0]
    total_favorites integer [default: 0]
    total_downloads integer [default: 0]
    reading_streak integer [default: 0]
    last_activity_date date
    total_reading_time integer [default: 0, note: 'in minutes']
    created_at timestamp [default: `CURRENT_TIMESTAMP`]
    updated_at timestamp [default: `CURRENT_TIMESTAMP`]
    
    indexes {
        user_id [unique]
        reading_streak
        last_activity_date
    }
}

// ============================================
// TABLE: user_preferences
// ============================================
Table user_preferences {
    id integer [pk, increment]
    user_id integer [not null]
    preference_key varchar(100) [not null]
    preference_value text
    created_at timestamp [default: `CURRENT_TIMESTAMP`]
    updated_at timestamp [default: `CURRENT_TIMESTAMP`]
    
    indexes {
        user_id
        preference_key
    }
    
    unique_constraint [user_id, preference_key]
}

// ============================================
// TABLE: user_bookmarks
// ============================================
Table user_bookmarks {
    id integer [pk, increment]
    user_id integer [not null]
    content_type content_type [not null]
    content_id integer [not null]
    page_number integer
    note text
    created_at timestamp [default: `CURRENT_TIMESTAMP`]
    
    indexes {
        user_id
        content_type
        content_id
    }
    
    unique_constraint [user_id, content_type, content_id]
}

// ============================================
// TABLE: user_highlights
// ============================================
Table user_highlights {
    id integer [pk, increment]
    user_id integer [not null]
    content_type content_type [not null]
    content_id integer [not null]
    start_position integer
    end_position integer
    highlighted_text text
    note text
    color varchar(20)
    created_at timestamp [default: `CURRENT_TIMESTAMP`]
    
    indexes {
        user_id
        content_type
        content_id
    }
}

// ============================================
// TABLE: author_publications
// ============================================
Table author_publications {
    id integer [pk, increment]
    author_id integer [not null, ref: > authors.id]
    publication_id integer [not null, ref: > publications.id]
    role varchar(50)
    contract_start date
    contract_end date
    is_active boolean [default: true]
    created_at timestamp [default: `CURRENT_TIMESTAMP`]
    updated_at timestamp [default: `CURRENT_TIMESTAMP`]
    
    indexes {
        author_id
        publication_id
        is_active
    }
    
    unique_constraint [author_id, publication_id]
}

// ============================================
// TABLE: publication_books
// ============================================
Table publication_books {
    id integer [pk, increment]
    publication_id integer [not null, ref: > publications.id]
    book_id integer [not null, ref: > books.id]
    published_date date
    edition varchar(50)
    isbn varchar(20)
    format varchar(50)
    created_at timestamp [default: `CURRENT_TIMESTAMP`]
    
    indexes {
        publication_id
        book_id
    }
    
    unique_constraint [publication_id, book_id]
}

// ============================================
// TABLE: book_contributors
// ============================================
Table book_contributors {
    id integer [pk, increment]
    book_id integer [not null, ref: > books.id]
    author_id integer [not null, ref: > authors.id]
    role varchar(50) [note: 'author, co-author, editor, illustrator, translator, narrator']
    created_at timestamp [default: `CURRENT_TIMESTAMP`]
    
    indexes {
        book_id
        author_id
        role
    }
}

// ============================================
// TABLE: author_stats
// ============================================
Table author_stats {
    id integer [pk, increment]
    author_id integer [not null, ref: > authors.id]
    total_books_published integer [default: 0]
    total_sales integer [default: 0]
    average_rating decimal(3,2) [default: 0.00]
    total_reviews integer [default: 0]
    total_views integer [default: 0]
    monthly_sales integer [default: 0]
    yearly_sales integer [default: 0]
    last_published_date date
    created_at timestamp [default: `CURRENT_TIMESTAMP`]
    updated_at timestamp [default: `CURRENT_TIMESTAMP`]
    
    indexes {
        author_id [unique]
        total_sales
        average_rating
    }
}

// ============================================
// TABLE: users
// ============================================
Table users {
    id integer [pk, increment]
    username varchar(100) [unique, not null]
    email varchar(200) [unique, not null]
    password_hash varchar(255) [not null]
    full_name varchar(200)
    avatar_url text
    bio text
    role user_role [default: 'user']
    is_active boolean [default: true]
    last_login timestamp
    created_at timestamp [default: `CURRENT_TIMESTAMP`]
    updated_at timestamp [default: `CURRENT_TIMESTAMP`]
    deleted_at timestamp
    
    indexes {
        username [unique]
        email [unique]
        role
        is_active
    }
}

// ============================================
// TABLE: sessions
// ============================================
Table sessions {
    id integer [pk, increment]
    user_id integer [not null, ref: > users.id]
    token varchar(255) [unique, not null]
    expires_at timestamp [not null]
    ip_address varchar(50)
    user_agent text
    created_at timestamp [default: `CURRENT_TIMESTAMP`]
    
    indexes {
        token [unique]
        user_id
        expires_at
    }
}

// ============================================
// TABLE: notifications
// ============================================
Table notifications {
    id integer [pk, increment]
    user_id integer [not null, ref: > users.id]
    type varchar(50)
    title varchar(200)
    message text
    is_read boolean [default: false]
    link text
    created_at timestamp [default: `CURRENT_TIMESTAMP`]
    read_at timestamp
    
    indexes {
        user_id
        is_read
        created_at
    }
}

// ============================================
// TABLE: bookmarks
// ============================================
Table bookmarks {
    id integer [pk, increment]
    user_id integer [not null, ref: > users.id]
    content_type content_type [not null]
    content_id integer [not null]
    created_at timestamp [default: `CURRENT_TIMESTAMP`]
    
    indexes {
        user_id
        content_type
        content_id
    }
    
    unique_constraint [user_id, content_type, content_id]
}

// ============================================
// TABLE: tags
// ============================================
Table tags {
    id integer [pk, increment]
    name varchar(100) [unique, not null]
    slug varchar(100) [unique, not null]
    description text
    created_at timestamp [default: `CURRENT_TIMESTAMP`]
    
    indexes {
        name [unique]
        slug [unique]
    }
}

// ============================================
// TABLE: genres
// ============================================
Table genres {
    id integer [pk, increment]
    name varchar(100) [unique, not null]
    slug varchar(100) [unique, not null]
    description text
    created_at timestamp [default: `CURRENT_TIMESTAMP`]
    
    indexes {
        name [unique]
        slug [unique]
    }
}

// ============================================
// TABLE: book_tags
// ============================================
Table book_tags {
    book_id integer [not null, ref: > books.id]
    tag_id integer [not null, ref: > tags.id]
    created_at timestamp [default: `CURRENT_TIMESTAMP`]
    
    indexes {
        book_id
        tag_id
    }
}

// ============================================
// TABLE: book_genres
// ============================================
Table book_genres {
    book_id integer [not null, ref: > books.id]
    genre_id integer [not null, ref: > genres.id]
    created_at timestamp [default: `CURRENT_TIMESTAMP`]
    
    indexes {
        book_id
        genre_id
    }
}

// ============================================
// TABLE: comic_tags
// ============================================
Table comic_tags {
    comic_id integer [not null, ref: > comics.id]
    tag_id integer [not null, ref: > tags.id]
    created_at timestamp [default: `CURRENT_TIMESTAMP`]
    
    indexes {
        comic_id
        tag_id
    }
}

// ============================================
// TABLE: comic_genres
// ============================================
Table comic_genres {
    comic_id integer [not null, ref: > comics.id]
    genre_id integer [not null, ref: > genres.id]
    created_at timestamp [default: `CURRENT_TIMESTAMP`]
    
    indexes {
        comic_id
        genre_id
    }
}

// ============================================
// TABLE: author_followers
// ============================================
Table author_followers {
    id integer [pk, increment]
    user_id integer [not null, ref: > users.id]
    author_id integer [not null, ref: > authors.id]
    created_at timestamp [default: `CURRENT_TIMESTAMP`]
    
    indexes {
        user_id
        author_id
    }
    
    unique_constraint [user_id, author_id]
}

// ============================================
// TABLE: category_followers
// ============================================
Table category_followers {
    id integer [pk, increment]
    user_id integer [not null, ref: > users.id]
    category_id integer [not null, ref: > categories.id]
    created_at timestamp [default: `CURRENT_TIMESTAMP`]
    
    indexes {
        user_id
        category_id
    }
    
    unique_constraint [user_id, category_id]
}