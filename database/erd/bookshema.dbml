// ============================================
// BOOKQUBIT BOOK SECTION ERD
// Complete Book-related Database Schema with Sample Data
// ============================================

// Project: BookQubit - Books Module
// Version: 1.0.0
// Database: SQLite
// Date: 2024

// ============================================
// ENUMS
// ============================================

Enum book_status {
    draft
    published
    archived
    deleted
}

Enum reading_status {
    to_read
    reading
    completed
    abandoned
    on_hold
}

Enum content_type {
    book
    author
    category
    publication
}

Enum trend_type {
    popular
    trending
    rising
    declining
}

Enum trend_period {
    daily
    weekly
    monthly
    yearly
}

// ============================================
// TABLES
// ============================================

// --------------------------------------------
// Table: languages
// --------------------------------------------
Table languages {
    id integer [primary key]
    code varchar(20) [unique, not null]
    name varchar(100) [not null]
    native_name varchar(100)
    flag_emoji varchar(10)
    is_active boolean [default: true]
    created_at timestamp [default: `CURRENT_TIMESTAMP`]
    updated_at timestamp [default: `CURRENT_TIMESTAMP`]
    
    indexes {
        code [unique]
        is_active
    }
}

// --------------------------------------------
// Table: authors
// --------------------------------------------
Table authors {
    id integer [primary key]
    name varchar(200) [not null]
    bio text
    birth_date date
    death_date date
    nationality varchar(100)
    language_code varchar(20)
    image_url text
    website varchar(255)
    wikipedia_url varchar(255)
    social_links text [note: 'JSON: {twitter, instagram, facebook}']
    total_books integer [default: 0]
    total_sales integer [default: 0]
    rating decimal(3,2) [default: 0.00]
    is_active boolean [default: true]
    created_at timestamp [default: `CURRENT_TIMESTAMP`]
    updated_at timestamp [default: `CURRENT_TIMESTAMP`]
    
    indexes {
        name
        language_code
        is_active
        rating
    }
}

// --------------------------------------------
// Table: categories
// --------------------------------------------
Table categories {
    id integer [primary key]
    name varchar(100) [not null]
    slug varchar(100) [unique, not null]
    description text
    icon varchar(50)
    color varchar(20)
    parent_id integer
    language_code varchar(20)
    is_active boolean [default: true]
    created_at timestamp [default: `CURRENT_TIMESTAMP`]
    updated_at timestamp [default: `CURRENT_TIMESTAMP`]
    
    indexes {
        slug [unique]
        parent_id
        language_code
        is_active
    }
}

// --------------------------------------------
// Table: publications
// --------------------------------------------
Table publications {
    id integer [primary key]
    name varchar(200) [not null]
    slug varchar(200) [unique, not null]
    description text
    logo_url text
    website varchar(255)
    founded_year integer
    country varchar(100)
    language_code varchar(20)
    email varchar(100)
    phone varchar(50)
    address text
    is_active boolean [default: true]
    created_at timestamp [default: `CURRENT_TIMESTAMP`]
    updated_at timestamp [default: `CURRENT_TIMESTAMP`]
    
    indexes {
        slug [unique]
        language_code
        is_active
        country
    }
}

// --------------------------------------------
// Table: books (MAIN TABLE)
// --------------------------------------------
Table books {
    id integer [primary key]
    title varchar(500) [not null]
    slug varchar(500) [unique, not null]
    subtitle varchar(500)
    author_id integer
    category_id integer
    language_code varchar(20) [not null]
    publication_id integer
    description text
    summary text
    excerpt text
    price decimal(10,2) [default: 0.00]
    currency varchar(10) [default: 'USD']
    image_url text
    cover_image text
    page_count integer
    isbn varchar(20) [unique]
    isbn13 varchar(20)
    oclc varchar(50)
    lccn varchar(50)
    publisher varchar(200)
    published_date date
    edition varchar(50)
    format varchar(50)
    rating decimal(3,2) [default: 0.00]
    total_reviews integer [default: 0]
    views integer [default: 0]
    downloads integer [default: 0]
    favorites integer [default: 0]
    shares integer [default: 0]
    status book_status [default: 'published']
    is_featured boolean [default: false]
    is_bestseller boolean [default: false]
    is_new_release boolean [default: false]
    table_of_contents text [note: 'JSON']
    tags text [note: 'JSON array']
    genres text [note: 'JSON array']
    subjects text [note: 'JSON array']
    key_points text [note: 'JSON array']
    geography text [note: 'JSON object']
    buttons text [note: 'JSON object']
    original_language_code varchar(20)
    created_at timestamp [default: `CURRENT_TIMESTAMP`]
    updated_at timestamp [default: `CURRENT_TIMESTAMP`]
    deleted_at timestamp
    
    indexes {
        slug [unique]
        author_id
        category_id
        language_code
        publication_id
        status
        rating
        created_at
        published_date
        is_featured
        is_bestseller
        isbn [unique]
        deleted_at
    }
}

// --------------------------------------------
// Table: book_contributors
// --------------------------------------------
Table book_contributors {
    id integer [primary key]
    book_id integer [not null]
    author_id integer [not null]
    role varchar(50) [note: 'author, co-author, editor, illustrator, translator']
    created_at timestamp [default: `CURRENT_TIMESTAMP`]
    
    indexes {
        book_id
        author_id
        role
    }
}

// --------------------------------------------
// Table: publication_books
// --------------------------------------------
Table publication_books {
    id integer [primary key]
    publication_id integer [not null]
    book_id integer [not null]
    published_date date
    edition varchar(50)
    isbn varchar(20)
    format varchar(50)
    created_at timestamp [default: `CURRENT_TIMESTAMP`]
    
    indexes {
        publication_id
        book_id
    }
}

// --------------------------------------------
// Table: reviews
// --------------------------------------------
Table reviews {
    id integer [primary key]
    content_type content_type [not null]
    content_id integer [not null]
    user_id integer
    user_name varchar(200)
    user_email varchar(200)
    rating integer [check: `rating >= 1 AND rating <= 5`]
    comment text
    title varchar(200)
    is_verified boolean [default: false]
    is_approved boolean [default: false]
    helpful_count integer [default: 0]
    unhelpful_count integer [default: 0]
    created_at timestamp [default: `CURRENT_TIMESTAMP`]
    updated_at timestamp [default: `CURRENT_TIMESTAMP`]
    
    indexes {
        content_type
        content_id
        rating
        created_at
        is_approved
    }
}

// --------------------------------------------
// Table: reading_list
// --------------------------------------------
Table reading_list {
    id integer [primary key]
    user_id integer [not null]
    content_type content_type [not null]
    content_id integer [not null]
    status reading_status [default: 'to_read']
    started_at timestamp
    completed_at timestamp
    progress integer [default: 0]
    rating integer [check: `rating >= 1 AND rating <= 5`]
    notes text
    created_at timestamp [default: `CURRENT_TIMESTAMP`]
    updated_at timestamp [default: `CURRENT_TIMESTAMP`]
    
    indexes {
        user_id
        content_type
        content_id
        status
    }
}

// --------------------------------------------
// Table: book_stats
// --------------------------------------------
Table book_stats {
    id integer [primary key]
    content_type content_type [not null]
    content_id integer [not null]
    daily_views integer [default: 0]
    weekly_views integer [default: 0]
    monthly_views integer [default: 0]
    daily_downloads integer [default: 0]
    weekly_downloads integer [default: 0]
    monthly_downloads integer [default: 0]
    daily_favorites integer [default: 0]
    weekly_favorites integer [default: 0]
    monthly_favorites integer [default: 0]
    daily_shares integer [default: 0]
    weekly_shares integer [default: 0]
    monthly_shares integer [default: 0]
    date date [not null]
    created_at timestamp [default: `CURRENT_TIMESTAMP`]
    
    indexes {
        content_type
        content_id
        date
    }
}

// --------------------------------------------
// Table: book_history
// --------------------------------------------
Table book_history {
    id integer [primary key]
    content_type content_type [not null]
    content_id integer [not null]
    action varchar(50) [not null]
    changes text [note: 'JSON']
    user_id integer
    user_name varchar(200)
    ip_address varchar(50)
    user_agent text
    created_at timestamp [default: `CURRENT_TIMESTAMP`]
    
    indexes {
        content_type
        content_id
        created_at
        action
    }
}

// --------------------------------------------
// Table: tags
// --------------------------------------------
Table tags {
    id integer [primary key]
    name varchar(100) [unique, not null]
    slug varchar(100) [unique, not null]
    description text
    created_at timestamp [default: `CURRENT_TIMESTAMP`]
    
    indexes {
        name [unique]
        slug [unique]
    }
}

// --------------------------------------------
// Table: genres
// --------------------------------------------
Table genres {
    id integer [primary key]
    name varchar(100) [unique, not null]
    slug varchar(100) [unique, not null]
    description text
    created_at timestamp [default: `CURRENT_TIMESTAMP`]
    
    indexes {
        name [unique]
        slug [unique]
    }
}

// --------------------------------------------
// Table: book_tags
// --------------------------------------------
Table book_tags {
    book_id integer [not null]
    tag_id integer [not null]
    created_at timestamp [default: `CURRENT_TIMESTAMP`]
    
    indexes {
        book_id
        tag_id
    }
}

// --------------------------------------------
// Table: book_genres
// --------------------------------------------
Table book_genres {
    book_id integer [not null]
    genre_id integer [not null]
    created_at timestamp [default: `CURRENT_TIMESTAMP`]
    
    indexes {
        book_id
        genre_id
    }
}

// ============================================
// RELATIONSHIPS (REFERENCES)
// ============================================

// Languages relationships
Ref: authors.language_code > languages.code
Ref: categories.language_code > languages.code
Ref: publications.language_code > languages.code
Ref: books.language_code > languages.code

// Books relationships
Ref: books.author_id > authors.id
Ref: books.category_id > categories.id
Ref: books.publication_id > publications.id

// Book contributors relationships
Ref: book_contributors.book_id > books.id
Ref: book_contributors.author_id > authors.id

// Publication books relationships
Ref: publication_books.publication_id > publications.id
Ref: publication_books.book_id > books.id

// Category self-reference
Ref: categories.parent_id > categories.id

// Reviews relationships
Ref: reviews.content_id > books.id

// Reading list relationships
Ref: reading_list.content_id > books.id

// Book stats relationships
Ref: book_stats.content_id > books.id

// Book history relationships
Ref: book_history.content_id > books.id

// Tags relationships
Ref: book_tags.book_id > books.id
Ref: book_tags.tag_id > tags.id

// Genres relationships
Ref: book_genres.book_id > books.id
Ref: book_genres.genre_id > genres.id

