// ============================================================================
// BookQubit Database
// Schema: Authentication
// File: ER_DIAGRAM.dbml
// Description: Authentication Schema ER Diagram
// ============================================================================

Table users {
  user_id integer [pk, increment]
  uuid text [unique, not null]
  email text [unique, not null]
  password_hash text
  auth_provider text
  status text
  created_at datetime
}

Table user_profiles {
  profile_id integer [pk, increment]
  user_id integer [not null]
  display_name text
  avatar_url text
  created_at datetime
}

Table user_settings {
  setting_id integer [pk, increment]
  user_id integer [not null]
  language_code text
  theme text
  created_at datetime
}

Table google_accounts {
  google_account_id integer [pk, increment]
  user_id integer [not null]
  google_id text [unique, not null]
  email text
  created_at datetime
}

Table sessions {
  session_id integer [pk, increment]
  user_id integer [not null]
  session_token text [unique]
  expires_at datetime
  created_at datetime
}

Table refresh_tokens {
  refresh_token_id integer [pk, increment]
  user_id integer [not null]
  token text [unique]
  expires_at datetime
  created_at datetime
}

Table auth_tokens {
  auth_token_id integer [pk, increment]
  user_id integer [not null]
  token text [unique]
  token_type text
  expires_at datetime
  created_at datetime
}

Table email_verifications {
  verification_id integer [pk, increment]
  user_id integer [not null]
  token text
  verified_at datetime
  created_at datetime
}

Table password_resets {
  reset_id integer [pk, increment]
  user_id integer [not null]
  token text
  expires_at datetime
  created_at datetime
}

Table login_history {
  login_id integer [pk, increment]
  user_id integer [not null]
  login_provider text
  ip_address text
  user_agent text
  login_at datetime
}

// Relationships

Ref: user_profiles.user_id > users.user_id
Ref: user_settings.user_id > users.user_id
Ref: google_accounts.user_id > users.user_id
Ref: sessions.user_id > users.user_id
Ref: refresh_tokens.user_id > users.user_id
Ref: auth_tokens.user_id > users.user_id
Ref: email_verifications.user_id > users.user_id
Ref: password_resets.user_id > users.user_id
Ref: login_history.user_id > users.user_id