# ============================================
# DATABASE CONFIGURATION
# ============================================

# Database Type: sqlite, postgres, mysql
DB_TYPE=sqlite

# SQLite Configuration
DB_PATH=./bookqubit_database.db
DB_JOURNAL_MODE=WAL
DB_SYNCHRONOUS=NORMAL
DB_CACHE_SIZE=10000
DB_TEMP_STORE=MEMORY

# PostgreSQL Configuration (for production)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=bookqubit
DB_USER=bookqubit_user
DB_PASSWORD=secure_password_here
DB_SSL_CA=/path/to/ca.pem
DB_SSL_CERT=/path/to/cert.pem
DB_SSL_KEY=/path/to/key.pem

# MySQL Configuration (alternative)
DB_HOST=localhost
DB_PORT=3306
DB_NAME=bookqubit
DB_USER=bookqubit_user
DB_PASSWORD=secure_password_here

# ============================================
# CONNECTION POOL
# ============================================
DB_POOL_MIN=2
DB_POOL_MAX=10
DB_IDLE_TIMEOUT=30000
DB_ACQUIRE_TIMEOUT=60000
DB_CONNECTION_TIMEOUT=5000

# ============================================
# QUERY SETTINGS
# ============================================
DB_QUERY_TIMEOUT=30000
DB_TRANSACTION_TIMEOUT=60000
DB_MIGRATION_TIMEOUT=120000
DB_SEED_TIMEOUT=300000
DB_SLOW_QUERY_THRESHOLD=1000

# ============================================
# LOGGING
# ============================================
DB_LOGGING=true
DB_LOG_LEVEL=debug
DB_LOG_QUERIES=true
DB_LOG_ERRORS=true

# ============================================
# MIGRATIONS
# ============================================
DB_RUN_MIGRATIONS=true

# ============================================
# SEEDS
# ============================================
DB_RUN_SEEDS=false

# ============================================
# BACKUP
# ============================================
DB_AUTO_BACKUP=true
DB_BACKUP_RETENTION=7
DB_BACKUP_COMPRESS=true
DB_BACKUP_INTERVAL=0 0 * * *

# ============================================
# PERFORMANCE
# ============================================
DB_ENABLE_INDEXES=true
DB_ENABLE_TRIGGERS=true
DB_ENABLE_VIEWS=true
DB_ENABLE_CACHING=true
DB_QUERY_CACHE_SIZE=100
DB_STATEMENT_CACHE_SIZE=50

# ============================================
# VALIDATION
# ============================================
DB_VALIDATE_ON_START=true
DB_VALIDATE_FOREIGN_KEYS=true
DB_VALIDATE_DATA_TYPES=true
DB_VALIDATE_CONSTRAINTS=true
DB_STRICT_MODE=false

# ============================================
# RETRY
# ============================================
DB_RETRY_ATTEMPTS=5
DB_RETRY_DELAY=1000
DB_RETRY_BACKOFF=exponential

# ============================================
# SCHEMA
# ============================================
DB_DEFAULT_SCHEMA=main
DB_SEARCH_PATH=main
DB_ENABLE_FOREIGN_KEYS=true
DB_ENABLE_CONSTRAINTS=true

# ============================================
# ENVIRONMENT
# ============================================
NODE_ENV=development