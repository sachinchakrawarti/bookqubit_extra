{
  "name": "bookqubit-api",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "generate": "plop",
    "gen:module": "plop module",
    "gen:component": "plop component",
    "gen:query": "plop query",
    "gen:api": "plop api",
    "gen:batch": "plop batch",
    "test": "cross-env NODE_OPTIONS=--experimental-vm-modules jest",
    "test:watch": "cross-env NODE_OPTIONS=--experimental-vm-modules jest --watch",
    "test:coverage": "cross-env NODE_OPTIONS=--experimental-vm-modules jest --coverage",
    "test:unit": "cross-env NODE_OPTIONS=--experimental-vm-modules jest --testMatch='**/tests/unit/**/*.test.js'",
    "test:integration": "cross-env NODE_OPTIONS=--experimental-vm-modules jest --testMatch='**/tests/integration/**/*.test.js'",
    "test:e2e": "cross-env NODE_OPTIONS=--experimental-vm-modules jest --testMatch='**/tests/e2e/**/*.test.js'",
    "test:ci": "cross-env NODE_OPTIONS=--experimental-vm-modules jest --ci --coverage --maxWorkers=2",
    "test:report": "start test-reports/index.html"
  },
  "dependencies": {
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "express": "^4.18.2",
    "express-rate-limit": "^6.10.0",
    "helmet": "^7.0.0",
    "morgan": "^1.10.0",
    "sqlite": "^5.1.1",
    "sqlite3": "^5.1.6",
    "winston": "^3.10.0"
  },
  "devDependencies": {
    "@jest/globals": "^30.4.1",
    "chai": "^6.2.2",
    "cross-env": "^10.1.0",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-jest": "^29.15.4",
    "eslint-plugin-node": "^11.1.0",
    "eslint-plugin-security": "^4.0.1",
    "handlebars": "^4.7.9",
    "husky": "^9.1.7",
    "jest": "^30.4.2",
    "jest-environment-node": "^30.4.1",
    "jest-html-reporter": "^4.4.0",
    "jest-junit": "^17.0.0",
    "lint-staged": "^17.0.8",
    "nodemon": "^3.0.1",
    "nyc": "^18.0.0",
    "plop": "^4.0.5",
    "sinon": "^22.0.0",
    "supertest": "^7.2.2"
  }
}
