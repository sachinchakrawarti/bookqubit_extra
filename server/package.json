{
  "name": "bookqubit-api",
  "version": "1.0.0",
  "type": "module",
  
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "generate": "plop",
    "gen:module": "plop module",
    "gen:component": "plop component",
    "gen:query": "plop query",
    "gen:api": "plop api",
    "gen:batch": "plop batch",
    "test": "cross-env NODE_OPTIONS=--experimental-vm-modules jest --config jest.config.js --runInBand",
    "test:watch": "cross-env NODE_OPTIONS=--experimental-vm-modules jest --config jest.config.js --watch",
    "test:coverage": "cross-env NODE_OPTIONS=--experimental-vm-modules jest --config jest.config.js --coverage",
    "test:unit": "cross-env NODE_OPTIONS=--experimental-vm-modules jest --config jest.config.js --testMatch='**/tests/unit/**/*.test.js'",
    "test:integration": "cross-env NODE_OPTIONS=--experimental-vm-modules jest --config jest.config.js --testMatch='**/tests/integration/**/*.test.js'",
    "test:e2e": "cross-env NODE_OPTIONS=--experimental-vm-modules jest --config jest.config.js --testMatch='**/tests/e2e/**/*.test.js'",
    "test:ci": "cross-env NODE_OPTIONS=--experimental-vm-modules jest --config jest.config.js --ci --coverage --maxWorkers=2",
    "test:simple": "cross-env NODE_OPTIONS=--experimental-vm-modules jest --config jest.config.js src/api/v1/modules/geography/tests/simple.test.js",
    "test:geo": "cross-env NODE_OPTIONS=--experimental-vm-modules jest --config jest.config.js src/api/v1/modules/geography/tests/",
    "test:report": "start test-reports/index.html",
    "lint": "node scripts/lint/lint.js check",
    "lint:check": "node scripts/lint/lint.js check",
    "lint:fix": "node scripts/lint/lint.js fix",
    "lint:file": "node scripts/lint/lint.js file",
    "lint:watch": "node scripts/lint/lint.js watch",
    "lint:staged": "node scripts/lint/lint-staged.js",
    "format": "node scripts/lint/format.js fix",
    "format:check": "node scripts/lint/format.js check",
    "format:fix": "node scripts/lint/format.js fix",
    "format:file": "node scripts/lint/format.js file",
    "fix:all": "node scripts/lint/fix-all.js",
    "check:all": "node scripts/lint/check-all.js",
    "precommit": "node scripts/lint/pre-commit.js",
    "prepush": "node scripts/lint/pre-push.js",
    "prepare": "husky"
  
},
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "axios": "^1.18.1",
    "chalk": "^5.6.2",
    "compression": "^1.7.4",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^4.22.2",
    "express-rate-limit": "^6.10.0",
    "fs-extra": "^11.3.6",
    "helmet": "^7.2.0",
    "joi": "^18.2.3",
    "knex": "^3.3.0",
    "lodash": "^4.17.21",
    "morgan": "^1.11.0",
    "prisma": "^5.22.0",
    "sequelize": "^6.37.8",
    "sqlite": "^5.1.1",
    "sqlite3": "^5.1.7",
    "winston": "^3.19.0"
  },
  "devDependencies": {
    "@jest/globals": "^30.4.1",
    "chai": "^6.2.2",
    "cross-env": "^10.1.0",
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^10.1.5",
    "eslint-config-standard": "^17.1.0",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-jest": "^29.15.4",
    "eslint-plugin-node": "^11.1.0",
    "eslint-plugin-prettier": "^5.5.4",
    "eslint-plugin-promise": "^7.3.0",
    "eslint-plugin-security": "^4.0.1",
    "eslint-plugin-standard": "^4.1.0",
    "handlebars": "^4.7.9",
    "husky": "^9.1.7",
    "jest": "^30.4.2",
    "jest-environment-node": "^30.4.1",
    "jest-html-reporter": "^4.4.0",
    "jest-junit": "^17.0.0",
    "lint-staged": "^17.0.8",
    "nodemon": "^3.1.14",
    "nyc": "^18.0.0",
    "plop": "^4.0.5",
    "prettier": "^3.0.0",
    "sinon": "^22.0.0",
    "supertest": "^7.2.2"
  },
  "lint-staged": {
    "*.js": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.json": [
      "prettier --write"
    ]
  }
}