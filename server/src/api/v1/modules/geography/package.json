    "geography",
    "countries",
    "states",
    "cities",
    "continents",
    "bookqubit"
  ],
  "author": "BookQbit Team",
  "license": "ISC",
  "private": true,
  "repository": {
    "type": "git",
    "url": "git+https://github.com/bookqubit/geography.git"
