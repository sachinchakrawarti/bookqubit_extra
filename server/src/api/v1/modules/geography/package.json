{
  "name": "@bookqubit/geography",
  "version": "1.0.0",
  "description": "Geography module for BookQbit - Manages countries, states, cities, and continents",
  "type": "module",
  "main": "index.js",
  "exports": {
    ".": "./index.js",
    "./config": "./config/geography.config.js",
    "./constants": "./constants/index.js",
    "./controllers": "./controllers/index.js",
    "./controllers/admin": "./controllers/admin/index.js",
